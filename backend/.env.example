# SIGSIS — Variáveis de Ambiente (Etapa 2)
# Copie este arquivo para .env e preencha os valores reais

# Servidor
PORT=3000
NODE_ENV=development

# Banco de Dados MySQL (Etapa 2)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=sigsis_db
DB_USER=sigsis_user
DB_PASS=senha_segura_aqui

# JWT (Etapa 2)
JWT_SECRET=troque_por_uma_chave_secreta_longa
JWT_EXPIRES_IN=8h

# Upload de arquivos (Etapa 2)
UPLOAD_MAX_SIZE_MB=10
UPLOAD_PATH=./uploads

# E-mail/SMTP (Etapa 3)
# SMTP_HOST=smtp.prefeitura.gov.br
# SMTP_PORT=587
# SMTP_USER=sigsis@prefeitura.gov.br
# SMTP_PASS=senha_smtp
